# FileMaker Data API base URL for PGH_Item_Distribution
# Example: https://your-filemaker-server.com/fmi/data/v1/databases/PGH_Item_Distribution
# Leave empty to run without FileMaker; grid still works locally.
VITE_FILEMAKER_BASE_URL=

# Optional: pre-fill the Connect dialog (do not commit real credentials)
# VITE_FILEMAKER_USER=
# VITE_FILEMAKER_PASSWORD=

# Optional: credentials for vendor self-service (cheque collection via QR code).
# If not set, falls back to VITE_FILEMAKER_USER/PASSWORD. Vendors scan QR on
# Cheque collection page to record collection without officer login.
# VITE_FILEMAKER_VENDOR_USER=
# VITE_FILEMAKER_VENDOR_PASSWORD=

# Smart Search: AI for natural language parsing (optional)
# Set VITE_SMART_SEARCH_AI_PROVIDER to: openai | anthropic | ollama
# When set, Smart Search uses AI instead of rules for flexible grammar.
#
# OpenAI:
# VITE_SMART_SEARCH_AI_PROVIDER=openai
# VITE_OPENAI_API_KEY=sk-...
# VITE_OPENAI_MODEL=gpt-4o-mini
#
# Anthropic Claude:
# VITE_SMART_SEARCH_AI_PROVIDER=anthropic
# VITE_ANTHROPIC_API_KEY=sk-ant-...
# VITE_ANTHROPIC_MODEL=claude-3-haiku-20240307
#
# Ollama (local, no API key):
# VITE_SMART_SEARCH_AI_PROVIDER=ollama
# VITE_OLLAMA_BASE_URL=http://localhost:11434
# VITE_OLLAMA_MODEL=llama3.2

